# Automatic nix develop activation
use flake

# Environment variables
export CEREBRO_DB="postgresql://cerebro@localhost/cerebro"
export REDIS_URL="redis://localhost:6379/0"
export IPFS_API="/ip4/127.0.0.1/tcp/5001"
export MODEL_REGISTRY="$PWD/configs/models.toml"

# Python
export PYTHONPATH="$PWD/src:$PYTHONPATH"
export PYTHONUNBUFFERED=1

# Development
export LOG_LEVEL="DEBUG"
export RUST_LOG="debug"

echo "🧠 CEREBRO Reranker dev environment loaded"
