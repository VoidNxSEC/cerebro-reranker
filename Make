.PHONY: dev build test train deploy clean

# Development
dev:
	uvicorn src.reranker.server:app --reload --host 0.0.0.0 --port 8000

# Build containers
build:
	nix build .#reranker-api
	nix build .#trainer

# Test
test:
	pytest tests/ -v --cov=src

# Training
train:
	nix run .#train

# Deploy
deploy:
	sudo nixos-rebuild switch --flake .#cerebro-reranker

# Benchmark
bench:
	python scripts/benchmark.py

# Clean
clean:
	rm -rf result
	rm -rf /tmp/cerebro-*
